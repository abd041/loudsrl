# Public site URL (sitemap, Open Graph, canonical)
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Contact form — email notifications (recommended)
# 1. Create a free account at https://resend.com and add an API key
# 2. On the free plan, verify the same address in Resend (required when using onboarding@resend.dev)
RESEND_API_KEY=re_your_api_key_here
CONTACT_NOTIFY_EMAIL=client@example.com
# Optional: use your own domain after verifying it in Resend
# CONTACT_FROM_EMAIL=LOUD Contact <contact@yourdomain.com>

# Optional: also POST JSON to CRM / Zapier
# CONTACT_WEBHOOK_URL=https://your-endpoint.example/hooks/contact

# When true (or on Vercel production), form returns 503 if neither email nor webhook is configured
CONTACT_REQUIRE_WEBHOOK=true

# Observability (optional)
NEXT_PUBLIC_VERCEL_ANALYTICS=true
NEXT_PUBLIC_VERCEL_SPEED_INSIGHTS=true
# NEXT_PUBLIC_REPORT_WEB_VITALS=true
# NEXT_PUBLIC_ERROR_REPORT_URL=https://your-error-webhook.example/log
